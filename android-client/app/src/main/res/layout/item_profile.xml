<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/twoman_white"
    app:cardCornerRadius="24dp"
    app:strokeColor="@color/twoman_outline"
    app:strokeWidth="1dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/profileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/twoman_black"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/profileBroker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/twoman_muted" />

        <TextView
            android:id="@+id/profilePorts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/twoman_muted" />

        <TextView
            android:id="@+id/profileModeState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/proxyButton"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/action_proxy"
                android:textSize="13sp"
                app:icon="@drawable/ic_proxy"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                app:iconSize="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/vpnButton"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/action_vpn"
                android:textSize="13sp"
                app:icon="@drawable/ic_vpn"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                app:iconSize="16dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/editButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/action_edit"
                android:textSize="12sp"
                android:maxLines="1"
                app:icon="@drawable/ic_edit"
                app:iconGravity="textStart"
                app:iconPadding="2dp"
                app:iconSize="14dp"
                app:iconTint="@color/twoman_black" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/shareButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/action_share"
                android:textSize="12sp"
                android:maxLines="1"
                app:icon="@drawable/ic_share"
                app:iconGravity="textStart"
                app:iconPadding="2dp"
                app:iconSize="14dp"
                app:iconTint="@color/twoman_black" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/deleteButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/action_delete"
                android:textSize="12sp"
                android:maxLines="1"
                app:icon="@drawable/ic_delete"
                app:iconGravity="textStart"
                app:iconPadding="2dp"
                app:iconSize="14dp"
                app:iconTint="@color/twoman_black" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
