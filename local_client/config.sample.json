{
  "broker_base_url": "https://host.example.com/api/v1/telemetry",
  "client_token": "replace-with-client-token",
  "auth_mode": "bearer",
  "legacy_custom_headers_enabled": false,
  "binary_media_type": "image/webp",
  "route_template": "/{lane}/{direction}",
  "health_template": "/health",
  "listen_host": "127.0.0.1",
  "http_listen_port": 0,
  "socks_listen_port": 0,
  "listen_state_path": "runtime/listen-state.json",
  "log_path": "logs/helper.log",
  "event_log_path": "logs/helper-events.ndjson",
  "log_max_bytes": 5242880,
  "log_backup_count": 3,
  "event_log_max_bytes": 10485760,
  "event_log_backup_count": 5,
  "recent_event_limit": 200,
  "http_timeout_seconds": 30,
  "heartbeat_interval_seconds": 15,
  "down_read_timeout_seconds": 10,
  "down_stream_max_session_seconds": 60,
  "interval_jitter_ratio": 0.2,
  "backoff_initial_delay_seconds": 0.1,
  "backoff_max_delay_seconds": 5,
  "flush_delay_seconds": 0.01,
  "max_batch_bytes": 65536,
  "enforce_connect_sni": true,
  "vpn_prefer_ipv4": true,
  "vpn_filter_aaaa": true,
  "http2_enabled": {
    "ctl": false,
    "data": false
  }
}
